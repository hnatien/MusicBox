# Discord Bot Token (REQUIRED) — from https://discord.com/developers
DISCORD_TOKEN=

# Discord Application/Client ID (REQUIRED)
CLIENT_ID=

# Guild ID for development (OPTIONAL — for guild-specific command registration)
DEV_GUILD_ID=

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Default volume (1-100)
DEFAULT_VOLUME=50

# Max queue size per guild
MAX_QUEUE_SIZE=100

# Inactivity timeout in seconds before auto-disconnect
INACTIVITY_TIMEOUT=300

# yt-dlp timeout overrides in milliseconds
# YT_METADATA_TIMEOUT_MS=30000
# YT_PLAYLIST_TIMEOUT_MS=45000
# YT_STREAM_TIMEOUT_MS=30000

# Manual cookie string for YouTube requests
# YOUTUBE_COOKIE=
